# Dagster Webserver Configuration
DAGSTER_WEBSERVER_HOST=0.0.0.0
DAGSTER_WEBSERVER_PORT=3000
DAGSTER_HOME=
DAGSTER_MAX_CONCURRENT_RUNS=2

# Dagster / dbt Target Configuration
# Determines which profile configuration is used in dbt_project/profiles.yml
# Valid options: development, sandbox, production
DBT_TARGET={{ cookiecutter.default_env }}
DBT_THREADS=4
DBT_PROJECT_DIR=./dbt_project
DBT_PROFILES_DIR=./dbt_project
LUBAN_REPO_ROOT=

# Generate `target/manifest.json` automatically if missing (used by Dagster dbt assets)
LUBAN_DBT_PREPARE_ON_LOAD=1

# OpenTelemetry (OTEL) export
# By default, export is disabled. To enable traces export, set:
#   OTEL_TRACES_EXPORTER=otlp
# Optional: enable metrics export (note: this code location mainly emits traces/spans today):
#   OTEL_METRICS_EXPORTER=otlp
# Protocol:
# - grpc: use OTEL_EXPORTER_OTLP_ENDPOINT as host:port (no scheme), e.g. localhost:8200
# - http/protobuf: use http(s)://host:port, e.g. http://localhost:8200
# Authentication (optional):
# - If your APM server requires a secret token or API key, pass it as an Authorization header:
#     OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <apm_secret_token>
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:8200
OTEL_SERVICE_NAME={{ cookiecutter.namespace ~ '/' if cookiecutter.namespace else '' }}{{ cookiecutter.package_name }}
OTEL_RESOURCE_ATTRIBUTES=service.namespace={{ cookiecutter.namespace if cookiecutter.namespace else 'dagster' }},deployment.environment.name={{ cookiecutter.default_env }}

# Required for daily partitions (this template uses daily partitions by default)
DAGSTER_DAILY_PARTITIONS_START_DATE=2026-03-01

# Optional: Partition change propagator mode
# - sensor (default): trigger daily facts per-partition after upstream dbt partitions materialize
# - eager: rely on Dagster eager automation for dws daily models (latest partition behavior)
LUBAN_PARTITION_CHANGE_PROPAGATOR_MODE=sensor

# Optional: Propagator catch-up
# When set to a positive integer, the propagation sensors will scan upstream materializations
# from the last N days on first startup (when no cursor exists yet) and enqueue downstream
# runs for those partitions.
LUBAN_PARTITION_CHANGE_PROPAGATOR_CATCHUP_DAYS=0

# Optional: Observation schedule
# Cron for ODS/source observation checks.
LUBAN_OBSERVE_SOURCES_CRON=*/5 * * * *

# StarRocks Database Configuration
# These are required to connect Dagster and dbt to StarRocks
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_USER=root
STARROCKS_PASSWORD=
STARROCKS_USE_PURE=true
{% if cookiecutter.default_env == 'development' %}{% set sr_env = 'dev' %}{% elif cookiecutter.default_env == 'sandbox' %}{% set sr_env = 'snd' %}{% else %}{% set sr_env = 'prd' %}{% endif %}
STARROCKS_ODS_DB={{ (cookiecutter.namespace ~ '_' if cookiecutter.namespace else '') ~ cookiecutter.package_name }}_ods_{{ sr_env }}
STARROCKS_DWD_DB={{ (cookiecutter.namespace ~ '_' if cookiecutter.namespace else '') ~ cookiecutter.package_name }}_dwd_{{ sr_env }}
STARROCKS_DWS_DB={{ (cookiecutter.namespace ~ '_' if cookiecutter.namespace else '') ~ cookiecutter.package_name }}_dws_{{ sr_env }}
STARROCKS_DB={{ (cookiecutter.namespace ~ '_' if cookiecutter.namespace else '') ~ cookiecutter.package_name }}_dws_{{ sr_env }}

# Optional: Override schema/database names used for dbt models

# Optional: Override query timeouts
# STARROCKS_QUERY_TIMEOUT_SECONDS=3600
# STARROCKS_PLANNER_OPTIMIZE_TIMEOUT_MS=300000
